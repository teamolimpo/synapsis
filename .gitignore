# Library/ is the mount point for the private vault (teamolimpo/synapsis-vault).
# It must never be committed in this public repo.
# New clones have no Library entry at all.
# Tensor-mill members create the external symlink with the simple commands:
#   bash scripts/vault-mount.sh
#   or: synapsis vault mount
Library/
# (no .gitkeep exceptions needed anymore — the vault manages its own content)

# Local low-latency Synapsis runtime memory (SQLite DB + WAL/SHM).
# This is the hot operational store (.synapsis is deliberately separate from
# Library/, which is intended for higher-latency curated/static vault content).
.synapsis/

# Logs and temp
*.log
tmp/
temp/
*.tmp
