# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
.venv/
venv/
ENV/
env/

# UV / package manager
uv.lock

# IDE / editors
.idea/
.vscode/
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Secrets
.env
.env.*
*.pem
*.key

# The actual team memory (never commit the DB or private vault content)
Library/
!Library/.gitkeep
!Library/**/.gitkeep
!Library/System/Poros/.gitignore

# Local low-latency Synapsis runtime memory (SQLite DB + WAL/SHM).
# This is the hot operational store (.synapsis is deliberately separate from
# Library/, which is intended for higher-latency curated/static vault content).
.synapsis/

# Logs and temp
*.log
tmp/
temp/
*.tmp
